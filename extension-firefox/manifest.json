{
  "manifest_version": 3,
  "name": "PiP カンペツール Hotkeys for Firefox",
  "description": "PiPカンペツールをFirefoxのショートカットで操作します。",
  "version": "1.0.0",
  "action": {
    "default_title": "PiP カンペツール Hotkeys for Firefox"
  },
  "permissions": ["scripting", "tabs"],
  "host_permissions": ["https://linn-0412.github.io/pip-kanpe-tool/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://linn-0412.github.io/pip-kanpe-tool/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "previous-card": {
      "suggested_key": {
        "default": "Ctrl+Shift+8"
      },
      "description": "前のカンペへ"
    },
    "next-card": {
      "suggested_key": {
        "default": "Ctrl+Shift+9"
      },
      "description": "次のカンペへ"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pip-kanpe-tool-hotkeys-firefox@linn-0412.github.io"
    }
  }
}
